# FloatChat — Environment Variables
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────────────
DB_NAME=floatchat
DB_USER=postgres
DB_PASS=your_postgres_password_here
DB_HOST=localhost
DB_PORT=5432

# ── LLM ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
